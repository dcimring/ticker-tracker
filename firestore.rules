rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Watchlist rules
    match /watchlist/{itemId} {
      // Allow users to manage their own items
      allow read, write: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid);
      // FALLBACK FOR SERVER SYNC: Allow unauthenticated access if it's a background sync
      // WARNING: This is a temporary measure because firebase-admin is failing to bypass rules in this environment.
      allow read, update: if true; 
    }

    // User Configs rules
    match /userConfigs/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      // FALLBACK FOR SERVER SYNC
      allow read: if true;
    }

    // System Metadata rules
    match /system_meta/{document} {
      allow read: if true;
      allow write: if false; // Only admin can write
    }

    // Default deny
    match /{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
